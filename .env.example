# Configuração do MontesBot

# Provedor de LLM (groq ou google_genai)
LLM_PROVIDER=groq
# Modelo específico (ex: llama-3.1-8b-instant ou gemini-2.0-flash)
LLM_MODEL=llama-3.1-8b-instant

# Chaves de API (preencher conforme o provedor escolhido)
GROQ_API_KEY=tua_chave_aqui
GEMINI_API_KEY=tua_chave_aqui

# Configurações do Scraper
SCRAPE_ADMIN_TOKEN=token_secreto_para_manual_scrape
SCRAPE_INTERVAL_HOURS=24

# Caminho para a base de dados vetorial
CHROMA_DB_PATH=./chroma_db
